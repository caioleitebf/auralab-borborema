# Configuracao de secrets do AuraLab Borborema
#
# Local: copie este arquivo para .streamlit/secrets.toml
# Streamlit Cloud: cole o conteudo na area "Secrets" do app (Settings)
#
# Como gerar o hash de uma senha:
#   python -c "import bcrypt; print(bcrypt.hashpw('SENHA'.encode(), bcrypt.gensalt()).decode())"

[auth]
cookie_name = "auralab_auth"
cookie_key  = "GERE-UMA-CHAVE-ALEATORIA-LONGA-AQUI"
cookie_days = 7

[auth.usuarios.caio]
nome    = "Caio Leite Brandao Ferreira"
email   = "caio.ferreira@auraminerals.com"
senha   = "$2b$12$..."   # bcrypt hash
perfil  = "admin"

[auth.usuarios.relyson]
nome    = "Relyson"
email   = "relyson@auraminerals.com"
senha   = "$2b$12$..."
perfil  = "user"
